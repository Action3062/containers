+<style scoped>
+.nest-cta.theme-dark {
+  --panel-2: #2d2d30;
+  --border: #3c3c3c;
+  --text: #d4d4d4;
+  --muted: #9da0a6;
+  --accent: #007acc;
+  --accent-2: #0e639c;
+  --focus: #3794ff;
+}
+.nest-cta {
+  display: block;
+  padding: 0 16px 8px;
+  color: var(--text);
+}
+.nest-cta .container { max-width: 960px; margin: 0 auto; }
+.nest-cta-card {
+  display: flex;
+  align-items: center;
+  gap: 16px;
+  padding: 10px 14px;
+  background: var(--panel-2);
+  border: 1px solid var(--border);
+  border-left: 3px solid var(--accent);
+  border-radius: 8px;
+  flex-wrap: wrap;
+}
+.nest-cta-logo {
+  width: 44px;
+  height: 44px;
+  flex-shrink: 0;
+  object-fit: contain;
+}
+.nest-cta-text { flex: 1 1 280px; min-width: 0; }
+.nest-cta-heading {
+  margin: 0 0 2px 0;
+  font-size: 13.5px;
+  font-weight: 600;
+  color: var(--text);
+  line-height: 1.3;
+}
+.nest-cta-body {
+  margin: 0;
+  color: var(--muted);
+  font-size: 12.5px;
+  line-height: 1.45;
+}
+.nest-cta-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 8px;
+  flex-shrink: 0;
+}
+.nest-cta-link {
+  display: inline-flex;
+  align-items: center;
+  padding: 6px 12px;
+  border-radius: 6px;
+  border: 1px solid var(--border);
+  font-size: 12.5px;
+  text-decoration: none;
+  white-space: nowrap;
+  transition: background 120ms ease, border-color 120ms ease, color 120ms ease;
+}
+.nest-cta-link.primary {
+  background: linear-gradient(180deg, var(--accent), var(--accent-2));
+  border-color: transparent;
+  color: #fff;
+}
+.nest-cta-link.primary:hover { filter: brightness(1.08); }
+.nest-cta-link.ghost {
+  background: transparent;
+  color: #d4d4d4;
+}
+.nest-cta-link.ghost:hover { background: rgba(255, 255, 255, 0.04); border-color: #4b4b4b; }
+.nest-cta-link:focus-visible {
+  outline: 2px solid var(--focus);
+  outline-offset: 2px;
+}
+@media (max-width: 560px) {
+  .nest-cta-card { flex-direction: column; align-items: center; text-align: center; }
+  .nest-cta-actions { justify-content: stretch; align-self: stretch; }
+  .nest-cta-link { flex: 1 1 auto; justify-content: center; }
+}
+</style>
